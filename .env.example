# === MinIO ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_RAW=raw-documents
MINIO_BUCKET_PROCESSED=processed-chunks
MINIO_BUCKET_ARTIFACTS=graph-artifacts

# GraphRAG 3 usa armazenamento em arquivo; artefatos são espelhados neste bucket via scripts.
# (Blob nativo no GraphRAG 3 é Azure; MinIO é integrado pela camada de sincronização.)

# === vLLM (OpenAI-compatible) — duas instâncias recomendadas ===
VLLM_LLM_BASE_URL=http://localhost:8000/v1
VLLM_EMBEDDING_BASE_URL=http://localhost:8001/v1
VLLM_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_EMBEDDING_MODEL=BAAI/bge-m3
VLLM_API_KEY=token-local

# Compat: URL única (só use se LLM e embeddings estiverem no mesmo servidor)
# VLLM_BASE_URL=http://localhost:8000/v1

# === GraphRAG ===
GRAPHRAG_ROOT=data
GRAPHRAG_INPUT_DIR=data/input

# === Geral ===
LOG_LEVEL=INFO
